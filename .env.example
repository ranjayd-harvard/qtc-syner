# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_strong_password_here

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32 random bytes as 64-char hex string
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_string_00000000000000000000000000000000

# ─── Internal Service Auth ────────────────────────────────────────────────────
# Shared secret between web and connector-api
# Generate: openssl rand -hex 32
CONNECTOR_INTERNAL_KEY=replace_with_64_char_hex_string_11111111111111111111111111111111

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3061/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_nextauth_secret_base64_string
NEXTAUTH_URL=http://localhost:3061

# ─── Seed Admin User ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Select which AI provider to use for data syncing features (gemini | claude | openai)
# Must be set in both forms so it's available server-side and in client bundles
NEXT_PUBLIC_AI_PROVIDER=gemini

# Google Gemini (default)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (set NEXT_PUBLIC_AI_PROVIDER=claude to use)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (set NEXT_PUBLIC_AI_PROVIDER=openai to use)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Ports ────────────────────────────────────────────────────────────────────
WEB_PORT=3061
